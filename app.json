{
  "expo": {
    "name": "AF Home",
    "slug": "Apsara-Mobile-Application",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon1.png",
    "userInterfaceStyle": "light",
    "scheme": "afhome",
    "splash": {
      "image": "./assets/splash-icon1.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.afhome.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon1.png",
        "backgroundColor": "#ffffff"
      },
      "notification": {
        "icon": "./assets/af_home_logo.png",
        "color": "#0ea5e9"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.afhome.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-video",
      "expo-font",
      "expo-secure-store",
      "expo-web-browser",
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "b17d81ff-81ab-4804-baf7-00452fe7daac"
      }
    },
    "owner": "ryderhxrzy"
  }
}