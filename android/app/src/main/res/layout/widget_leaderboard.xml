<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background"
    android:gravity="top">

    <!-- Header -->
    <TextView
        android:id="@+id/widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🎯 Top Referrers"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#13a1d4"
        android:layout_marginBottom="12dp" />

    <!-- Leaderboard Items Container -->
    <LinearLayout
        android:id="@+id/leaderboard_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Item 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="6dp">
            <TextView
                android:layout_width="24dp"
                android:layout_height="wrap_content"
                android:text="1"
                android:textStyle="bold"
                android:textColor="#13a1d4"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/user_1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Loading..."
                android:textSize="12sp"
                android:textColor="#333333" />
            <TextView
                android:id="@+id/points_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-- referrals"
                android:textSize="12sp"
                android:textColor="#666666" />
        </LinearLayout>

        <!-- Item 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="6dp">
            <TextView
                android:layout_width="24dp"
                android:layout_height="wrap_content"
                android:text="2"
                android:textStyle="bold"
                android:textColor="#13a1d4"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/user_2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Loading..."
                android:textSize="12sp"
                android:textColor="#333333" />
            <TextView
                android:id="@+id/points_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-- referrals"
                android:textSize="12sp"
                android:textColor="#666666" />
        </LinearLayout>

        <!-- Item 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="6dp">
            <TextView
                android:layout_width="24dp"
                android:layout_height="wrap_content"
                android:text="3"
                android:textStyle="bold"
                android:textColor="#13a1d4"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/user_3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Loading..."
                android:textSize="12sp"
                android:textColor="#333333" />
            <TextView
                android:id="@+id/points_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-- referrals"
                android:textSize="12sp"
                android:textColor="#666666" />
        </LinearLayout>

        <!-- Item 4 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="6dp">
            <TextView
                android:layout_width="24dp"
                android:layout_height="wrap_content"
                android:text="4"
                android:textStyle="bold"
                android:textColor="#13a1d4"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/user_4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Loading..."
                android:textSize="12sp"
                android:textColor="#333333" />
            <TextView
                android:id="@+id/points_4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-- referrals"
                android:textSize="12sp"
                android:textColor="#666666" />
        </LinearLayout>

        <!-- Item 5 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="6dp">
            <TextView
                android:layout_width="24dp"
                android:layout_height="wrap_content"
                android:text="5"
                android:textStyle="bold"
                android:textColor="#13a1d4"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/user_5"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Loading..."
                android:textSize="12sp"
                android:textColor="#333333" />
            <TextView
                android:id="@+id/points_5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-- referrals"
                android:textSize="12sp"
                android:textColor="#666666" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
