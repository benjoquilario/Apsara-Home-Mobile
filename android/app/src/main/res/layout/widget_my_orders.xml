<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#ffffff"
    android:padding="12dp">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📦 My Orders"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#0066FF"
        android:layout_marginBottom="12dp" />

    <!-- Orders Container -->
    <LinearLayout
        android:id="@+id/orders_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="visible">

        <!-- Order 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/widget_order_card_bg"
            android:padding="10dp"
            android:layout_marginBottom="8dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="start">

                    <TextView
                        android:id="@+id/order_num_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Order #123456"
                        android:textSize="11sp"
                        android:textColor="#333333"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/order_date_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dec 15"
                        android:textSize="9sp"
                        android:textColor="#999999"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/order_status_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DELIVERED"
                    android:textSize="8sp"
                    android:textColor="#10b981"
                    android:textStyle="bold"
                    android:background="@drawable/widget_status_badge_bg"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="3dp"
                    android:gravity="center" />
            </LinearLayout>

            <TextView
                android:id="@+id/item_name_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Modern Coffee Table"
                android:textSize="10sp"
                android:textColor="#666666"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total: "
                    android:textSize="9sp"
                    android:textColor="#999999" />

                <TextView
                    android:id="@+id/order_amount_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₱2,499.00"
                    android:textSize="10sp"
                    android:textColor="#0066FF"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Order 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/widget_order_card_bg"
            android:padding="10dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="start">

                    <TextView
                        android:id="@+id/order_num_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Order #123455"
                        android:textSize="11sp"
                        android:textColor="#333333"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/order_date_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dec 10"
                        android:textSize="9sp"
                        android:textColor="#999999"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/order_status_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SHIPPED"
                    android:textSize="8sp"
                    android:textColor="#3b82f6"
                    android:textStyle="bold"
                    android:background="@drawable/widget_status_badge_bg"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="3dp"
                    android:gravity="center" />
            </LinearLayout>

            <TextView
                android:id="@+id/item_name_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Desk Lamp with USB"
                android:textSize="10sp"
                android:textColor="#666666"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total: "
                    android:textSize="9sp"
                    android:textColor="#999999" />

                <TextView
                    android:id="@+id/order_amount_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₱899.00"
                    android:textSize="10sp"
                    android:textColor="#0066FF"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/empty_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingVertical="20dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📭"
            android:textSize="32sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/empty_state_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No orders yet"
            android:textSize="12sp"
            android:textColor="#999999"
            android:gravity="center" />
    </LinearLayout>

    <!-- Decorative petals -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_horizontal"
        android:layout_marginTop="8dp">

        <TextView
            android:layout_width="4dp"
            android:layout_height="4dp"
            android:text="●"
            android:textColor="#0066FF"
            android:textSize="8sp"
            android:gravity="center"
            android:layout_margin="2dp" />

        <TextView
            android:layout_width="4dp"
            android:layout_height="4dp"
            android:text="●"
            android:textColor="#13a1d4"
            android:textSize="8sp"
            android:gravity="center"
            android:layout_margin="2dp" />

        <TextView
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:text="●"
            android:textColor="#0066FF"
            android:textSize="10sp"
            android:gravity="center"
            android:layout_margin="2dp" />

        <TextView
            android:layout_width="4dp"
            android:layout_height="4dp"
            android:text="●"
            android:textColor="#13a1d4"
            android:textSize="8sp"
            android:gravity="center"
            android:layout_margin="2dp" />

        <TextView
            android:layout_width="4dp"
            android:layout_height="4dp"
            android:text="●"
            android:textColor="#0066FF"
            android:textSize="8sp"
            android:gravity="center"
            android:layout_margin="2dp" />
    </LinearLayout>
</LinearLayout>
